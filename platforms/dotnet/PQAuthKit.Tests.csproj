<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <OutputType>Exe</OutputType>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
    <NoWarn>$(NoWarn);SYSLIB5006</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="src/PQAuthKit/PQAuthKit.csproj" />
    <Compile Include="tests/PQAuthKit.Tests/Program.cs" />
  </ItemGroup>
  <Target Name="RunPQAuthKitTests" BeforeTargets="VSTest" DependsOnTargets="Build">
    <Exec Command="dotnet &quot;$(TargetPath)&quot;" />
  </Target>
</Project>
